    <defaultLabelColor>(135,206,235)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <SocialImpact>0.15</SocialImpact>
          <NegotiationAbility>0.10</NegotiationAbility>
          <SuppressionPower>0.15</SuppressionPower>
          <ArrestSuccessChance>0.10</ArrestSuccessChance>
          <PawnBeauty>-0.5</PawnBeauty>
        </statOffsets>
      </li>
    </stages>
    <spawnThingOnRemoved>DRG_ServiceStud</spawnThingOnRemoved>
    <descriptionHyperlinks>
