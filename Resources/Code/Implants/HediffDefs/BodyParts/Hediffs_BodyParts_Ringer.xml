  <!-- Blade Arm -->

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>DRG_hediff_RetractableBladeArm</defName>
    <label>blade arm</label>
    <labelNoun>a blade arm</labelNoun>
    <description>An installed bionic arm with an integrated mono-molecular blade. When sheathed, the arm functions as a capable manipulator. When deployed, the blade extends for devastating close-quarters strikes.</description>
    <defaultLabelColor>(135,206,235)</defaultLabelColor>
    <addedPartProps>
      <solid>true</solid>
      <partEfficiency>1.10</partEfficiency>
      <betterThanNatural>true</betterThanNatural>
    </addedPartProps>
    <comps>
      <li Class="HediffCompProperties_VerbGiver">
        <tools>
          <li>
            <label>blade</label>
            <capacities>
              <li>Cut</li>
              <li>Stab</li>
            </capacities>
            <power>18</power>
            <cooldownTime>1.8</cooldownTime>
            <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
            <soundMeleeHit>MeleeHit_BionicPunch</soundMeleeHit>
            <soundMeleeMiss>MeleeMiss_BionicPunch</soundMeleeMiss>
          </li>
          <li>
            <label>fist</label>
            <capacities>
              <li>Blunt</li>
            </capacities>
            <power>9</power>
            <cooldownTime>2</cooldownTime>
            <soundMeleeHit>MeleeHit_BionicPunch</soundMeleeHit>
            <soundMeleeMiss>MeleeMiss_BionicPunch</soundMeleeMiss>
          </li>
        </tools>
      </li>
    </comps>
    <spawnThingOnRemoved>DRG_RetractableBladeArm</spawnThingOnRemoved>
    <descriptionHyperlinks>
      <ThingDef>DRG_RetractableBladeArm</ThingDef>
    </descriptionHyperlinks>
  </HediffDef>

