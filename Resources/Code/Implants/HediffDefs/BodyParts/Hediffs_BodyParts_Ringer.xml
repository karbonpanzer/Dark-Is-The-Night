<Defs>

  <!-- Neuro-Stabilizer -->

  <HediffDef ParentName="ImplantHediffBase">
    <defName>DRG_hediff_NeuroStabilizer</defName>
    <label>neuro-stabilizer</label>
    <labelNoun>a neuro-stabilizer</labelNoun>
    <description>An installed neural dampening module that regulates emotional spikes and suppresses panic responses. The recipient is far less likely to suffer mental breaks, but reports a persistent mental fog that slightly impairs higher cognition.</description>
    <defaultLabelColor>(135,206,235)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MentalBreakThreshold>-0.12</MentalBreakThreshold>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <spawnThingOnRemoved>DRG_NeuroStabilizer</spawnThingOnRemoved>
    <descriptionHyperlinks>
      <ThingDef>DRG_NeuroStabilizer</ThingDef>
    </descriptionHyperlinks>
  </HediffDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>DRG_NeuroStabilizer</defName>
    <label>neuro-stabilizer</label>
    <description>A neural dampening module designed for cranial implantation. It regulates emotional volatility and suppresses panic responses, making the recipient far more resistant to mental breaks at the cost of slightly dulled cognition.</description>
    <descriptionHyperlinks><RecipeDef>DRG_InstallNeuroStabilizer</RecipeDef></descriptionHyperlinks>
    <costList>
      <Plasteel>15</Plasteel>
      <ComponentSpacer>2</ComponentSpacer>
    </costList>
    <statBases>
      <Mass>0.3</Mass>
    </statBases>
  </ThingDef>

  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>DRG_InstallNeuroStabilizer</defName>
    <label>install neuro-stabilizer</label>
    <description>Install a neuro-stabilizer.</description>
    <descriptionHyperlinks>
      <ThingDef>DRG_NeuroStabilizer</ThingDef>
      <HediffDef>DRG_hediff_NeuroStabilizer</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing neuro-stabilizer.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>DRG_NeuroStabilizer</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>DRG_NeuroStabilizer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Brain</li>
    </appliedOnFixedBodyParts>
    <addsHediff>DRG_hediff_NeuroStabilizer</addsHediff>
  </RecipeDef>

  <RecipeDef ParentName="SurgeryRemoveImplantBase">
    <defName>DRG_RemoveNeuroStabilizer</defName>
    <label>remove neuro-stabilizer</label>
    <description>Remove neuro-stabilizer.</description>
    <descriptionHyperlinks>
      <ThingDef>DRG_NeuroStabilizer</ThingDef>
      <HediffDef>DRG_hediff_NeuroStabilizer</HediffDef>
    </descriptionHyperlinks>
    <jobString>Removing neuro-stabilizer.</jobString>
    <removesHediff>DRG_hediff_NeuroStabilizer</removesHediff>
  </RecipeDef>

