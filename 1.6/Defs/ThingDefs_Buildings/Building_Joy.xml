<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>UFR_Gamesphere</defName>
    <label>game sphere</label>
    <description>A high-tech spacer game console. Using advanced methods to create a holographic play area, it is considered the pinnacle of video game development. Creating a perfect immersion in whatever of the several hundred preloaded games it contains.\n\nImpossible to produce on most Rimworlds, it is often sold by merchant-scalpers looking to make a larger profit.</description>
    <category>Building</category>
    <graphicData>
      <texPath>Things/Building/Joy/Gamesphere/Gamesphere</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.4</fillPercent>
    <size>(1,1)</size>
    <rotatable>true</rotatable>
    <defaultPlacingRot>South</defaultPlacingRot>
    <techLevel>Spacer</techLevel>
    <socialPropernessMatters>true</socialPropernessMatters>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToBuild>6000</WorkToBuild>
      <Flammability>0.4</Flammability>
      <Mass>10</Mass>
      <Beauty>10</Beauty>
      <BeautyOutdoors>6</BeautyOutdoors>
      <MarketValue>1400</MarketValue>
      <JoyGainFactor>1.4</JoyGainFactor>
    </statBases>
    <costList>
      <Steel>50</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
      <ComponentSpacer>4</ComponentSpacer>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>200</basePowerConsumption>
        <shortCircuitInRain>true</shortCircuitInRain>
      </li>
      <li Class="CompProperties_Flickable" />
      <li Class="CompProperties_Breakdownable" />
      <li Class="CompProperties_Glower">
        <glowRadius>5</glowRadius>
        <glowColor>(200,140,240,0)</glowColor>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_WatchArea</li>
    </placeWorkers>
    <surfaceType>Item</surfaceType>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsJoy</li>
    </thingCategories>
    <tradeability>All</tradeability>
    <tradeTags>
      <li>ExoticMisc</li>
    </tradeTags>
    <designationCategory>Joy</designationCategory>
    <constructEffect>ConstructMetal</constructEffect>
    <researchPrerequisites>
      <li>MicroelectronicsBasics</li>
    </researchPrerequisites>
    <building>
      <joyKind>Television</joyKind>
      <watchBuildingStandDistanceRange>2~4</watchBuildingStandDistanceRange>
      <watchBuildingStandRectWidth>5</watchBuildingStandRectWidth>
      <watchBuildingInSameRoom>true</watchBuildingInSameRoom>
      <effectWatching>WatchingTelevision</effectWatching>
    </building>
  </ThingDef>

  <ThingDef ParentName="FurnitureWithQualityBase">
    <defName>UFR_WargamingTable</defName>
    <label>wargaming table</label>
    <description>A purpose-built tabletop for miniature wargaming. Sculpted terrain, painted regiments, dice and rulers. A frontier-favorite for those who enjoy intellectual contests of attrition and maneuver. Trains intellectual skills.\n\nThis building requires adjacent chairs or stools to use.</description>
    <graphicData>
      <texPath>Things/Building/Joy/WargamingTable/wargamingtable</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,4)</drawSize>
      <shadowData>
        <volume>(1.6, 0.3, 1.6)</volume>
        <offset>(0, 0, -0.15)</offset>
      </shadowData>
    </graphicData>
    <rotatable>true</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <socialPropernessMatters>true</socialPropernessMatters>
    <fillPercent>0.40</fillPercent>
    <minTechLevelToBuild>Industrial</minTechLevelToBuild>
    <building>
      <joyKind>Gaming_Cerebral</joyKind>
      <buildingSizeCategory>Medium</buildingSizeCategory>
      <paintable>true</paintable>
    </building>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>12000</WorkToBuild>
      <Mass>30</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>2</Beauty>
      <JoyGainFactor>1.4</JoyGainFactor>
    </statBases>
    <size>(2,2)</size>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>50</costStuffCount>
    <costList>
      <Steel>30</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <pathCost>42</pathCost>
    <passability>PassThroughOnly</passability>
    <designationCategory>Joy</designationCategory>
    <designationHotKey>Misc5</designationHotKey>
    <canOverlapZones>false</canOverlapZones>
    <researchPrerequisites>
      <li>UFR_FrontierEntertainment</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <uiIconScale>0.9</uiIconScale>
  </ThingDef>

  <!-- Build like poker for hte time being -->
  <ThingDef ParentName="FurnitureWithQualityBase">
    <defName>UFR_EuchreTable</defName>
    <label>euchre table</label>
    <description>A square card table designed for the four-player game of euchre. Played in two partnerships, it's a quick, sociable game popular on frontier worlds where space and time are at a premium.\n\nThis building requires adjacent chairs or stools to use.</description>
    <graphicData>
      <texPath>Things/Building/Joy/Euchre/euchre</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(4,4)</drawSize>      
      <shadowData>
        <volume>(1.6, 0.3, 1.6)</volume>
        <offset>(0, 0, -0.15)</offset>
      </shadowData>
      <damageData>
        <rect>(0.09375,0.296875,0.796875,0.703125)</rect>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <size>(2,2)</size>    
    <altitudeLayer>Building</altitudeLayer>
    <rotatable>false</rotatable>
    <socialPropernessMatters>true</socialPropernessMatters>
    <fillPercent>0.40</fillPercent>
    <minTechLevelToBuild>Industrial</minTechLevelToBuild>
    <building>
      <joyKind>Gaming_Cerebral</joyKind>
      <buildingSizeCategory>Medium</buildingSizeCategory>      
      <paintable>true</paintable>
    </building>
    <researchPrerequisites>
      <li>UFR_FrontierEntertainment</li>
    </researchPrerequisites>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <WorkToBuild>9000</WorkToBuild>
      <Mass>5</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>4</Beauty>
      <JoyGainFactor>1.1</JoyGainFactor>
    </statBases>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>80</costStuffCount>
    <costList>
      <Cloth>20</Cloth>
    </costList>
    <pathCost>30</pathCost>
    <passability>PassThroughOnly</passability>
    <designationCategory>Joy</designationCategory>
    <designationHotKey>Misc2</designationHotKey>
  </ThingDef>

</Defs>