  <!-- Vat-grown Arm -->
  <ThingDef ParentName="UFR_VatGrownPartBase">
    <defName>UFR_VatGrownArm</defName>
    <label>vat-grown arm</label>
    <description>An organic arm cultivated from lab-grown tissue. Denser musculature, reinforced bone, and engineered nerve fibers give it greater strength and dexterity than the natural arm it replaces.</description>
    <descriptionHyperlinks>
      <RecipeDef>UFR_InstallVatGrownArm</RecipeDef>
    </descriptionHyperlinks>
    <statBases>
      <MarketValue>2200</MarketValue>
      <Mass>2.0</Mass>
    </statBases>
    <costList>
      <UFR_LabGrownCulture>4</UFR_LabGrownCulture>
      <Neutroamine>4</Neutroamine>
      <Plasteel>3</Plasteel>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <recipeMaker>
      <workAmount>8000</workAmount>
    </recipeMaker>
  </ThingDef>

  <HediffDef ParentName="AddedBodyPartBase">
