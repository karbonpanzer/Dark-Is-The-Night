  <!-- Redundant Cardiac Bulb -->
  <ThingDef ParentName="UFR_BioImplantBase">
    <defName>UFR_CardiacBulb</defName>
    <label>redundant cardiac bulb</label>
    <description>A vat-grown auxiliary cardiac muscle, smaller than the original and seated below it. Engineered for failover and stress-mode circulation boost.</description>
    <descriptionHyperlinks>
      <RecipeDef>UFR_InstallCardiacBulb</RecipeDef>
    </descriptionHyperlinks>
    <statBases>
      <MarketValue>1800</MarketValue>
      <Mass>0.4</Mass>
    </statBases>
    <costList>
      <UFR_LabGrownCulture>4</UFR_LabGrownCulture>
      <Neutroamine>4</Neutroamine>
      <Plasteel>3</Plasteel>
      <ComponentSpacer>2</ComponentSpacer>
      <Luciferium>1</Luciferium>
    </costList>
    <recipeMaker>
      <workAmount>9000</workAmount>
    </recipeMaker>
  </ThingDef>

  <HediffDef ParentName="ImplantHediffBase">
    <defName>UFR_CardiacBulb</defName>
    <label>redundant cardiac bulb</label>
    <labelNoun>a redundant cardiac bulb</labelNoun>
    <description>An installed redundant cardiac bulb providing auxiliary circulation under stress.</description>
    <descriptionHyperlinks>
      <ThingDef>UFR_CardiacBulb</ThingDef>
    </descriptionHyperlinks>
    <spawnThingOnRemoved>UFR_CardiacBulb</spawnThingOnRemoved>
    <stages>
      <li>
        <statOffsets>
          <ImmunityGainSpeedFactor>0.10</ImmunityGainSpeedFactor>
        </statOffsets>
        <capMods>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.10</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>UFR_InstallCardiacBulb</defName>
    <label>install redundant cardiac bulb</label>
    <description>Install a redundant cardiac bulb.</description>
    <descriptionHyperlinks>
      <ThingDef>UFR_CardiacBulb</ThingDef>
      <HediffDef>UFR_CardiacBulb</HediffDef>
