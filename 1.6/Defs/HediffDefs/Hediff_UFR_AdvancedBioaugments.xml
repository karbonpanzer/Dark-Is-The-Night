    <techLevel>Spacer</techLevel>
    <thingSetMakerTags Inherit="False" />
    <recipeMaker>
      <researchPrerequisite>UFR_AdvancedBioAugments</researchPrerequisite>
      <recipeUsers>
        <li>UFR_BioAugmentBench</li>
      </recipeUsers>
      <workSkill>Intellectual</workSkill>
      <skillRequirements>
        <Intellectual>10</Intellectual>
      </skillRequirements>
    </recipeMaker>
  </ThingDef>

  <!-- Combat Vat-grown Arm -->
  <ThingDef ParentName="UFR_AdvancedVatGrownPartBase">
    <defName>UFR_AdvancedVatGrownArm</defName>
    <label>combat vat-grown arm</label>
    <description>A vat-grown arm engineered for combat. Bone density increased, slow-twitch muscle largely replaced with fast-twitch fibers, and neural pathways pre-tuned for weapon manipulation. Surpasses the base vat-grown arm in every combat-relevant metric.</description>
    <descriptionHyperlinks>
      <RecipeDef>UFR_InstallAdvancedVatGrownArm</RecipeDef>
    </descriptionHyperlinks>
    <statBases>
      <MarketValue>3200</MarketValue>
      <Mass>2.4</Mass>
    </statBases>
    <costList>
      <UFR_VatGrownArm>1</UFR_VatGrownArm>
      <UFR_LabGrownCulture>8</UFR_LabGrownCulture>
      <Neutroamine>8</Neutroamine>
      <Plasteel>5</Plasteel>
      <ComponentSpacer>2</ComponentSpacer>
    </costList>
    <recipeMaker>
      <workAmount>12000</workAmount>
    </recipeMaker>
  </ThingDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>UFR_AdvancedVatGrownArm</defName>
    <label>combat vat-grown arm</label>
    <labelNoun>a combat vat-grown arm</labelNoun>
    <description>An installed combat vat-grown arm. Combat-tuned, organic, and engineered to outperform both natural and base vat-grown equivalents.</description>
    <descriptionHyperlinks>
      <ThingDef>UFR_AdvancedVatGrownArm</ThingDef>
    </descriptionHyperlinks>
    <spawnThingOnRemoved>UFR_AdvancedVatGrownArm</spawnThingOnRemoved>
    <addedPartProps>
      <solid>false</solid>
      <partEfficiency>1.45</partEfficiency>
      <betterThanNatural>true</betterThanNatural>
    </addedPartProps>
  </HediffDef>

  <RecipeDef ParentName="SurgeryInstallBodyPartArtificialBase">
    <defName>UFR_InstallAdvancedVatGrownArm</defName>
    <label>install combat vat-grown arm</label>
    <description>Install a combat vat-grown arm.</description>
    <descriptionHyperlinks>
      <ThingDef>UFR_AdvancedVatGrownArm</ThingDef>
      <HediffDef>UFR_AdvancedVatGrownArm</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing combat vat-grown arm.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>UFR_AdvancedVatGrownArm</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>UFR_AdvancedVatGrownArm</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Shoulder</li>
    </appliedOnFixedBodyParts>
    <addsHediff>UFR_AdvancedVatGrownArm</addsHediff>
  </RecipeDef>

