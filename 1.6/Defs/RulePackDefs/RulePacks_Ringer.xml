<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <RulePackDef>
    <defName>DRG_Faction_Civil</defName>
    <include>
      <li>OutlanderPlaceNameUtility</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_name(p=6)->[political_adjective_expedition] [political_union_cap] of [nearnameinitial]</li>
        <li>r_name(p=4)->[political_adjective] [political_union_cap] of [nearnameinitial]</li>
        <li>r_name(p=2)->[nearnameinitial] [political_union_cap]</li>
        <li>political_union_standalone->[political_union_cap]</li>
        <li>nearnameinitial(p=3)->[PlaceOutlander]</li>
        <li>nearnameinitial(p=2)->[expedition_prefix] [PlaceOutlander]</li>
        <li>nearnameinitial->[Direction] [PlaceOutlander]</li>
      </rulesStrings>
      <rulesFiles>
        <li>political_union_cap->Words/Nouns/PoliticalUnions_ExpeditionCap</li>
        <li>political_adjective_expedition->Words/Adjectives/Political_Adjective_Expedition</li>
        <li>political_adjective->Words/Adjectives/PoliticalUnions</li>
        <li>expedition_prefix->Words/Adjectives/Expedition_Prefix</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>

  <RulePackDef>
    <defName>DRG_Faction_Rough</defName>
    <include>
      <li>OutlanderPlaceNameUtility</li>
    </include>
    <rulePack>
      <rulesStrings>
        <li>r_name(p=4)->The [pirate_adjective] [military_unit]</li>
        <li>r_name(p=4)->[pirate_leader]'s [military_unit]</li>
        <li>r_name(p=3)->[pirate_leader]'s Free Company</li>
        <li>r_name(p=3)->The [pirate_adjective] Free Company</li>
        <li>r_name(p=2)->[pirate_leader]'s Free [military_unit_free]</li>
        <li>r_name(p=3)->[pirate_leader]'s [gang_noun]</li>
        <li>r_name(p=2)->The [pirate_leader] [gang_noun]</li>
        <li>r_name(p=2)->The [concept_badass] [gang_noun]</li>
        <li>r_name(p=2)->The [pirate_adjective] [gang_noun]</li>
        <li>r_name(p=2)->[pirate_leader]'s [pirate_band]</li>
        <li>r_name(p=2)->The [pirate_adjective] [pirate_band]</li>
        <li>r_name->The [pirate_band] of [nearnameinitial]</li>
        <li>r_name->The [pirate_adjective] [military_unit] of [nearnameinitial]</li>
        <li>nearnameinitial(p=3)->[PlaceOutlander]</li>
        <li>nearnameinitial->[Direction] [PlaceOutlander]</li>
      </rulesStrings>
      <rulesFiles>
        <li>pirate_leader->Names/PirateLeaderNames</li>
        <li>pirate_band->Words/Nouns/PirateBandNouns</li>
        <li>military_unit->Words/Nouns/MilitaryUnits</li>
        <li>military_unit_free->Words/Nouns/MilitaryUnits_Free</li>
        <li>pirate_adjective->Words/Adjectives/PirateAdjectives</li>
        <li>concept_badass->Words/Nouns/Concepts_Badass</li>
        <li>gang_noun->Words/Nouns/GangNouns</li>
      </rulesFiles>
    </rulePack>
  </RulePackDef>

</Defs>
