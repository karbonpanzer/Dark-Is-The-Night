<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>DRG_Webbing_GrenadierTox</defName>
		<description>A load-bearing chest harness built to carry toxin grenades. Chemically resistant inner lining and sealed canister clips prevent accidental exposure to the lethal chemical agents during movement.</description>
		<label>Grenadier Webbing (Tox)</label>
		<recipeMaker>
		  <researchPrerequisite>DRG_SpecialistAccessories</researchPrerequisite>
		</recipeMaker>
		<graphicData>
		  <texPath>Things/Pawn/Humanlike/Accessories/GrenadierWebbing/GrenadierWebbing</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		  <color>(0.40,0.34,0.22)</color>
    </graphicData>
		<costList>
      <Steel>40</Steel>
      <Cloth>40</Cloth>
    </costList>
    <stuffCategories Inherit="False" IsNull="True" />
		<statBases>
		  <MaxHitPoints>200</MaxHitPoints>
		  <WorkToMake>6000</WorkToMake>
		  <Mass>1</Mass>
		  <EquipDelay>1</EquipDelay>
		</statBases>
		<comps>
		  <li Class="CompProperties_ApparelReloadable">
			<maxCharges>8</maxCharges>
			<ammoDef>Weapon_GrenadeTox</ammoDef>
			<ammoCountToRefill>1</ammoCountToRefill>
			<baseReloadTicks>60</baseReloadTicks>
			<soundReload>Standard_Reload</soundReload>
			<hotKey>Misc4</hotKey>
			<chargeNoun>tox</chargeNoun>
			<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		  </li>
		</comps>
	    <thingCategories>
		  <li>DRG_Accessories</li>
		</thingCategories>
		<equippedStatOffsets>
		  <PainShockThreshold>0.10</PainShockThreshold>	  
		</equippedStatOffsets>   
		<apparel>
			<drawData>
                <dataSouth>
                    <layer>21.5</layer>
                </dataSouth>
                <dataWest>
				    <layer>21.5</layer>
                </dataWest>
                <dataEast>
				    <layer>21.5</layer>
                </dataEast>
                <dataNorth>
			        <layer>21.5</layer>
                </dataNorth>
			</drawData>				
		  <bodyPartGroups>
			<li>Torso</li>
			<li>Shoulders</li>
			<li>Waist</li>        
		  </bodyPartGroups>
		  <wornGraphicPath>Things/Pawn/Humanlike/Accessories/GrenadierWebbing/GrenadierWebbing</wornGraphicPath>
		  <wornGraphicData>
       		 <renderUtilityAsPack>false</renderUtilityAsPack>
    	  </wornGraphicData>
		  <layers>
			<li>Belt</li>
		  </layers>
		  <tags>
			<li>DRG_Accessories_Grenadier</li>
		  </tags>
		  <defaultOutfitTags>
			<li>Soldier</li>
		  </defaultOutfitTags>
		  <countsAsClothingForNudity>false</countsAsClothingForNudity>
		  <canBeDesiredForIdeo>true</canBeDesiredForIdeo>
		  <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
		  <useWornGraphicMask>True</useWornGraphicMask>			  
      <abilities>
        <li>DRG_Ability_ThrowTox</li>
      </abilities>
		</apparel>	
    <colorGenerator Class="ColorGenerator_Single">
      <color>(0.40,0.34,0.22)</color>
    </colorGenerator>	
	  <uiIconScale>1.15</uiIconScale>
	</ThingDef>

  <AbilityDef>
    <defName>DRG_Ability_ThrowTox</defName>
    <label>throw tox grenade</label>
    <description>Throw a toxic grenade. Consumes one charge from the grenadier webbing.</description>
    <iconPath>Things/Item/Equipment/WeaponRanged/ToxGrenades</iconPath>
    <gizmoClass>DeadRinger.CommandAbilityReloadable</gizmoClass>
    <aiCanUse>true</aiCanUse>
    <ai_IsOffensive>true</ai_IsOffensive>
    <ai_IsIncendiary>false</ai_IsIncendiary>
    <ai_SearchAOEForTargets>true</ai_SearchAOEForTargets>
    <hostile>true</hostile>
    <writeCombatLog>true</writeCombatLog>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>12.9</range>
      <warmupTime>1.5</warmupTime>
      <targetParams>
        <canTargetLocations>true</canTargetLocations>
        <canTargetPawns>true</canTargetPawns>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="DeadRinger.CompPropertiesAbilityEffectApparelReloadable">
        <ProjectileDef>Proj_GrenadeTox</ProjectileDef>
        <ForcedMissRadius>1.9</ForcedMissRadius>
        <SoundOnCast>ThrowGrenade</SoundOnCast>
      </li>
    </comps>
  </AbilityDef>
</Defs>