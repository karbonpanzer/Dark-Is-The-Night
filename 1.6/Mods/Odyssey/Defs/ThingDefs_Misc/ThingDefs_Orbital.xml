<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="ArmorHelmetMakeableBase">
    <defName>DRG_OrbitalMarauderHelmet</defName>
    <label>Orbital Marauder Helmet</label>
    <description>A fully sealed Marauder helmet rated for low-pressure environments. Integrated visor and pressure-lock collar allow short-duration operations in vacuum or near-vacuum conditions.</description>
    <techLevel>Spacer</techLevel>
    <recipeMaker>
      <researchPrerequisite>DRG_OrbitalMarauderArmor</researchPrerequisite>
      <recipeUsers>
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Helmets/EVAHelmet/EVAHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <statBases>
      <WorkToMake>20000</WorkToMake>
      <MaxHitPoints>120</MaxHitPoints>
      <Mass>1.4</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.88</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.36</ArmorRating_Blunt>
      <ArmorRating_Heat>0.44</ArmorRating_Heat>
      <Insulation_Cold>4</Insulation_Cold>
      <Insulation_Heat>2</Insulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <thingCategories>
      <li>DRG_Helmets</li>
    </thingCategories>
    <costList>
      <Steel>30</Steel>
      <Plasteel>15</Plasteel>
      <ComponentIndustrial>1</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <equippedStatOffsets>
      <MoveSpeed>-0.05</MoveSpeed>
      <ToxicEnvironmentResistance>0.8</ToxicEnvironmentResistance>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.69</VacuumResistance>
    </equippedStatOffsets>
    <apparel>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <immuneToToxGasExposure>true</immuneToToxGasExposure>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Helmets/EVAHelmet/EVAHelmet</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>DRG_Armor</li>
        <li>Vacsuit</li>
      </tags>
      <forceEyesVisibleForRotations>
        <li>1</li>
        <li>2</li>
        <li>3</li>
      </forceEyesVisibleForRotations>
      <defaultOutfitTags>
        <li>Spacefarer</li>
      </defaultOutfitTags>
    </apparel>
    <tradeTags>
      <li>HiTechArmor</li>
      <li>Armor</li>
    </tradeTags>
    <thingSetMakerTags>
      <li>RewardStandardMidFreq</li>
    </thingSetMakerTags>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>DRG_OrbitalMarauderArmor</defName>
    <label>Orbital Marauder Armor</label>
    <techLevel>Spacer</techLevel>
    <description>A vacuum-rated variant of standard Marauder armor, with sealed joints and passive pressure retention. Used by personnel conducting boarding actions or operations in low-pressure environments.</description>
    <recipeMaker>
      <researchPrerequisite>DRG_OrbitalMarauderArmor</researchPrerequisite>
    </recipeMaker>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Pawn/Humanlike/Armor/EVAArmor/EVAArmor</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>0.8</drawSize>
    </graphicData>
    <statBases>
      <WorkToMake>52000</WorkToMake>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>8</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.92</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.4</ArmorRating_Blunt>
      <ArmorRating_Heat>0.5</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>6</EquipDelay>
    </statBases>
    <thingCategories>
      <li>DRG_Armor</li>
    </thingCategories>
    <costList>
      <Steel>60</Steel>
      <Plasteel>35</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>
    <equippedStatOffsets>
      <MoveSpeed>-0.4</MoveSpeed>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">0.32</VacuumResistance>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/EVAArmor/EVAArmor</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>Middle</li>
      </layers>
      <tags>
        <li>DRG_Armor</li>
      </tags>
      <defaultOutfitTags>
        <li>Spacefarer</li>
      </defaultOutfitTags>
      <renderNodeProperties>
        <li Class="DeadRinger.PawnRenderNodePropertiesOmni">
          <nodeClass>DeadRinger.PawnRenderNodeDecal</nodeClass>
          <workerClass>DeadRinger.PawnRenderNodeWorkerHeadware</workerClass>
          <parentTagDef>ApparelHead</parentTagDef>
          <baseLayer>55</baseLayer>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.100</scale>
            <defaultData>
              <layer>75</layer>
              <offset>(0,0,0.17)</offset>
              <flip>true</flip>
            </defaultData>
          </drawData>
        </li>
      </renderNodeProperties>
    </apparel>
    <comps>
      <li Class="DeadRinger.CompPropertiesEditDecalMarker" />
    </comps>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>
</Defs>
