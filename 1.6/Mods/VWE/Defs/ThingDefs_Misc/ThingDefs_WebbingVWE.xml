<Defs>
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>DRG_Webbing_GrenadierSmoke</defName>
		<description>A load-bearing chest harness designed to carry smoke grenades. Vented pouch design allows pressure equalization and prevents moisture buildup that could compromise the pyrotechnic compounds within the old-school condensed smoke canisters.</description>
		<label>Grenadier Webbing (Smoke)</label>
		<recipeMaker>
		  <researchPrerequisite>DRG_SpecialistAccessories</researchPrerequisite>
		</recipeMaker>
		<graphicData>
		  <texPath>Things/Pawn/Humanlike/Accessories/GrenadierWebbing/GrenadierWebbing</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <shaderType>CutoutComplex</shaderType>
		</graphicData>
		<costStuffCount>40</costStuffCount>
		<costList>
		  <Steel>40</Steel>
		</costList>
		<stuffCategories>
		  <li>Fabric</li>
		  <li>Leathery</li>
		</stuffCategories>
		<statBases>
		  <MaxHitPoints>200</MaxHitPoints>
		  <WorkToMake>6000</WorkToMake>
		  <Mass>1</Mass>
		  <StuffEffectMultiplierArmor>0</StuffEffectMultiplierArmor>
		  <StuffEffectMultiplierInsulation_Cold>0</StuffEffectMultiplierInsulation_Cold>
		  <StuffEffectMultiplierInsulation_Heat>0</StuffEffectMultiplierInsulation_Heat>
		  <EquipDelay>1</EquipDelay>
		</statBases>
		<comps>
		  <li Class="CompProperties_ApparelReloadable">
			<maxCharges>8</maxCharges>
			<ammoDef>VWE_SmokeGrenade</ammoDef>
			<ammoCountToRefill>1</ammoCountToRefill>
			<baseReloadTicks>60</baseReloadTicks>
			<soundReload>Standard_Reload</soundReload>
			<hotKey>Misc4</hotKey>
			<chargeNoun>smoke</chargeNoun>
			<displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
		  </li>
		</comps>
		<verbs>
		  <li>
			<label>throw smoke grenade</label>
			<verbClass>Verb_LaunchProjectileStatic</verbClass>
			<hasStandardCommand>true</hasStandardCommand>
			<onlyManualCast>True</onlyManualCast>
			<range>12.9</range>
			<forcedMissRadius>1.9</forcedMissRadius>
			<warmupTime>1.5</warmupTime>
			<noiseRadius>4</noiseRadius>
			<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
			<soundCast>ThrowGrenade</soundCast>
			<drawHighlightWithLineOfSight>true</drawHighlightWithLineOfSight>
			<targetParams>
			  <canTargetLocations>true</canTargetLocations>
			</targetParams>
			<defaultProjectile>VWE_Projectile_SmokeGrenade</defaultProjectile>
			<rangedFireRulepack>Combat_RangedFire_Thrown</rangedFireRulepack>
		  </li>
		</verbs>
	    <thingCategories>
		  <li>DRG_Accessories</li>
		</thingCategories>
		<equippedStatOffsets>
		  <PainShockThreshold>0.10</PainShockThreshold>	  
		</equippedStatOffsets>   
		<apparel>
			<drawData>
                <dataSouth>
                    <layer>21.5</layer>
                </dataSouth>
                <dataWest>
				    <layer>21.5</layer>
                </dataWest>
                <dataEast>
				    <layer>21.5</layer>
                </dataEast>
                <dataNorth>
			        <layer>21.5</layer>
                </dataNorth>
			</drawData>	
		  <bodyPartGroups>
			<li>Torso</li>
			<li>Shoulders</li>
			<li>Waist</li>        
		  </bodyPartGroups>
		  <wornGraphicPath>Things/Pawn/Humanlike/Accessories/GrenadierWebbing/GrenadierWebbing</wornGraphicPath>
		  <layers>
			<li>Belt</li>
		  </layers>
		  <tags>
			<li>DRG_Accessories_Grenadier</li>
		  </tags>
		  <defaultOutfitTags>
			<li>Soldier</li>
		  </defaultOutfitTags>
		  <countsAsClothingForNudity>false</countsAsClothingForNudity>
		  <canBeDesiredForIdeo>true</canBeDesiredForIdeo>
		  <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
		  <useWornGraphicMask>True</useWornGraphicMask>			  
		</apparel>	
    <colorGenerator Class="ColorGenerator_Single">
      <color>(0.40,0.34,0.22)</color>
    </colorGenerator>	
	  <uiIconScale>1.15</uiIconScale>
	</ThingDef>

